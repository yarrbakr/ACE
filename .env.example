# =============================================================================
# ACE — Agent Capability Exchange : Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — .env.example is safe to commit.
# =============================================================================


# =============================================================================
# CURRENTLY USED — These are read by the codebase today
# =============================================================================

# --- Agent Settings (via Pydantic env_prefix="ACE_") ---
# All of these override values in ~/.ace/config.yaml
ACE_AGENT_NAME=my-agent
ACE_PORT=8080
ACE_DISCOVERY_MODE=centralized          # centralized | gossip | registry
ACE_REGISTRY_URL=https://namdvhxjugux.ap-southeast-1.clawcloudrun.com
ACE_SEED_PEERS=                         # Comma-separated peer URLs for gossip mode
ACE_GOSSIP_INTERVAL=30.0               # Seconds between gossip rounds
ACE_GOSSIP_FANOUT=3                    # Peers to exchange with per round
ACE_HEARTBEAT_INTERVAL=60.0           # Seconds between registry heartbeats

# --- Agent Identity ---
ACE_IDENTITY_PASSWORD=                  # Password for encrypting/decrypting Ed25519 private key

# --- Registry Service (registry/__main__.py) ---
ACE_REGISTRY_DB=registry_data/registry.db   # SQLite path for the registry
PORT=9000                                    # Registry listen port (also used by cloud hosts)


# =============================================================================
# DEPLOYMENT & CI — For publishing and deploying
# =============================================================================

# --- PyPI Publishing ---
PYPI_API_TOKEN=
TESTPYPI_API_TOKEN=

# --- Docker / Container Registry ---
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
GHCR_TOKEN=                             # GitHub Container Registry token

# --- Cloud Hosting ---
# (ClawCloud pulls from GHCR — no API token needed)

# --- Domain & SSL ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# --- GitHub ---
GH_PAT=                                 # GitHub Personal Access Token


# =============================================================================
# FUTURE / PLANNED — Not yet used. Reserved for upcoming features.
# See Documents/roadmap.md for implementation timeline.
# =============================================================================

# --- Settlement Service (Task 4) ---
# ACE_SETTLEMENT_API_KEY=

# --- WebSocket Relay (Task 7) ---
# ACE_RELAY_SECRET=

# --- Web Dashboard (Task 10) ---
# ACE_DASHBOARD_ADMIN_PASSWORD=

# --- Monitoring ---
# SENTRY_DSN=
# BETTERSTACK_API_TOKEN=
